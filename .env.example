# متغيرات البيئة لنظام الإشعارات

# =========================================
# API Configuration
# =========================================

# عنوان خادم Django API
REACT_APP_API_URL=http://localhost:8000/api

# عنوان WebSocket
REACT_APP_WS_URL=ws://localhost:8000

# =========================================
# Development/Production
# =========================================

# بيئة التطوير
REACT_APP_ENV=development

# =========================================
# Notification Settings
# =========================================

# عدد الإشعارات المعروضة في الصفحة الواحدة (افتراضي: 10)
REACT_APP_NOTIFICATIONS_PAGE_SIZE=10

# مدة ظهور Toast بالميلي ثانية (افتراضي: 5000)
REACT_APP_TOAST_DURATION=5000

# تفعيل إشعارات المتصفح (notification API)
REACT_APP_ENABLE_BROWSER_NOTIFICATIONS=true

# =========================================
# WebSocket Configuration
# =========================================

# محاولات إعادة الاتصال (null = بلا حد)
REACT_APP_WS_MAX_RECONNECT_ATTEMPTS=10

# فترة إعادة الاتصال بالميلي ثانية
REACT_APP_WS_RECONNECT_INTERVAL=5000

# =========================================
# Feature Flags
# =========================================

# تفعيل فلاتر الإشعارات حسب المتجر
REACT_APP_ENABLE_STORE_FILTER=true

# تفعيل حذف الإشعارات
REACT_APP_ENABLE_DELETE_NOTIFICATIONS=true

# تفعيل البحث في الإشعارات
REACT_APP_ENABLE_SEARCH=false

# =========================================
# Debugging
# =========================================

# تفعيل رسائل console
REACT_APP_DEBUG_NOTIFICATIONS=true
